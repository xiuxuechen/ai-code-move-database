<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN" "http://ibatis.apache.org/dtd/ibatis-3-mapper.dtd">
<!-- 命名空间 -->
<mapper namespace="com.cxsj.mxzd.mapper.pg.PgAuditFindDataBaseMapper">



    <sql id="AuditFindDataBaseVo">
        select id ,problem_summary,problem_description,audit_time,audit_involved,audit_project,
           audit_model_number,create_person,create_time,update_person,update_time,isdel from hpeapm.audit_elements_find_database
    </sql>

    <resultMap type="com.cxsj.mxzd.pojo.AuditFindDataBase" id="AuditFindDataBaseMap">
        <result property="id" column="id" />
        <result property="problemSummary" column="problem_summary" />
        <result property="problemDescription" column="problem_description" />
        <result property="auditTime" column="audit_time" />
        <result property="auditInvolved" column="audit_involved" />
        <result property="auditProject" column="audit_project" />
        <result property="auditModelNumber" column="audit_model_number" />
        <result property="createPerson" column="create_person" />
        <result property="createTime" column="create_time" />
        <result property="updatePerson" column="update_person" />
        <result property="updateTime" column="update_time" />
        <result property="isdel" column="isdel" />

    </resultMap>


    <!--查询审计发现库 -->
    <select id="selectAuditFindDataBase" resultMap="AuditFindDataBaseMap">
        <include refid="AuditFindDataBaseVo"/>
        <where>
            <if test="id != null ">and id LIKE '%'||#{id}||'%'</if>
            <if test="problemSummary != null "> and problem_summary like '%'||#{problemSummary}||'%'</if>
            <if test="problemDescription != null  and problemDescription != ''"> and problem_description like '%'||#{problemDescription}||'%'</if>
            <if test="auditTime != null  and auditTime != ''"> and audit_time LIKE '%'||#{auditTime}||'%'</if>
            <if test="auditInvolved != null  and auditInvolved != ''"> and audit_involved like '%'||#{auditInvolved}||'%'</if>
            <if test="auditProject != null "> and audit_project LIKE '%'||#{auditProject}||'%'</if>
            <if test="auditModelNumber != null "> and audit_model_number LIKE '%'||#{auditModelNumber}||'%'</if>
            <if test="createPerson != null "> and create_person LIKE '%'||#{createPerson}||'%'</if>
            <if test="createTime != null "> and create_time LIKE '%'||#{createTime}||'%'</if>
            <if test="updatePerson != null "> and update_person LIKE '%'||#{updatePerson}||'%'</if>
            <if test="updateTime != null "> and update_time LIKE '%'||#{updateTime}||'%'</if>
             and isdel =1
        </where>
    </select>


    <!--插入审计库内容-->
    <insert id="insertAuditFindDataBase" parameterType="com.cxsj.mxzd.pojo.AuditFindDataBase" keyProperty="id" useGeneratedKeys="true">
        insert into hpeapm.audit_elements_find_database
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="problemSummary != null ">problem_summary,</if>
            <if test="problemDescription != null  and problemDescription != ''">problem_description,</if>
            <if test="auditTime != null  and auditTime != ''">audit_time,</if>
            <if test="auditInvolved != null  and auditInvolved != ''">audit_involved,</if>
            <if test="auditProject != null">audit_project,</if>
            <if test="auditModelNumber != null">audit_model_number,</if>
            <if test="createPerson != null  and createPerson != ''">create_person,</if>
            <!--<if test="createTime != null  and createTime != ''">create_time,</if>-->
            create_time,
            <if test="updatePerson != null  and updatePerson != ''">update_person,</if>
            <!--<if test="updateTime != null  and updateTime != ''">update_time,</if>-->
            update_time,
            <if test="isdel != null  and isdel != ''">isdel,</if>

        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="problemSummary != null ">#{problemSummary},</if>
            <if test="problemDescription != null  and problemDescription != ''">#{problemDescription},</if>
            <if test="auditTime != null  and auditTime != ''">#{auditTime},</if>
            <if test="auditInvolved != null  and auditInvolved != ''">#{auditInvolved},</if>
            <if test="auditProject != null  ">#{auditProject},</if>
            <if test="auditModelNumber != null  ">#{auditModelNumber},</if>
            <if test="createPerson != null  and createPerson != ''">#{createPerson},</if>
            now(),
            <if test="updatePerson != null  and updatePerson != ''">#{updatePerson},</if>
            now(),
            <if test="isdel != null  and isdel != ''">#{isdel},</if>

        </trim>
    </insert>

<!--修改-->
    <update id="updateAuditFindDataBase">
        UPDATE hpeapm.audit_elements_find_database
        <trim prefix="SET" suffixOverrides=",">
            <if test="problemSummary != null ">problem_summary=#{problemSummary},</if>
            <if test="problemDescription != null  and problemDescription != ''">problem_description=#{problemDescription},</if>
            <if test="auditTime != null  and auditTime != ''">audit_time=#{auditTime},</if>
            <if test="auditInvolved != null  and auditInvolved != ''">audit_involved=#{auditInvolved},</if>
            <if test="auditProject != null">audit_project=#{auditProject},</if>
            <if test="auditModelNumber != null">audit_model_number=#{auditModelNumber},</if>
            <if test="createPerson != null  and createPerson != ''">create_person=#{createPerson},</if>
            <if test="createTime != null  and createTime != ''">create_time=#{createTime},</if>
            <if test="updatePerson != null  and updatePerson != ''">update_person=#{updatePerson},</if>
            <if test="updateTime != null  and updateTime != ''">update_time=#{updateTime},</if>
            <if test="isdel != null  and isdel != ''">isdel=#{isdel}</if>
        </trim>
        where audit_model_number LIKE '%'||#{auditModelNumber}||'%'
    </update>

        <!--删除-->
        <update id="deleteByAuditModelNumber">
            UPDATE hpeapm.audit_elements_find_database SET isdel=0  where audit_model_number LIKE '%'||#{auditModelNumber}||'%'
        </update>
    <select id="selectByAuditModelNumber" parameterType="java.lang.String" resultMap="AuditFindDataBaseMap">
        select * from hpeapm.audit_elements_find_database   where audit_model_number LIKE '%'||#{auditModelNumber}||'%' AND isdel=1;
    </select>



    <insert id="inserts" parameterType="java.util.List" >
        insert into hpeapm.audit_elements_find_database(id,problem_summary,problem_description,audit_time,audit_involved,audit_project,audit_model_number,
        create_person,create_time,update_person,update_time,isdel)
        values
        <foreach collection="list" item="auditFindDataBase" separator=",">
            (#{auditFindDataBase.id},#{auditFindDataBase.problemSummary}, #{auditFindDataBase.problemDescription},#{auditFindDataBase.auditTime},
            #{auditFindDataBase.auditInvolved},#{auditFindDataBase.auditProject},
            #{auditFindDataBase.auditModelNumber}, #{auditFindDataBase.createPerson}, now(),
            #{auditFindDataBase.updatePerson}, now(),1)
        </foreach>
    </insert>

</mapper>


