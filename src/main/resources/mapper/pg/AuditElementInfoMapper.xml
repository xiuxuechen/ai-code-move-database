    <!--根据模型编号修改step表当中的审计模型名称以及审计点名称-->
    <update id="updateModelStepTableModelMsgByModelNumber" parameterType="com.cxsj.mxzd.pojo.AuditElementInfo">
        UPDATE
            hpeapm."audit_elements_operation_steps" a
        SET a."audit_point_name" = #{auditPointName},
            a."audit_model_name" = #{auditModelName}
        WHERE a."audit_model_number" = #{auditModelNumber}
    </update>


    <!--根据模型编号修改model_type表当中的审计模型名称以及审计点名称-->
