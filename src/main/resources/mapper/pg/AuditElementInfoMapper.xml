    <select id="selectByAuditModelNumber" parameterType="java.lang.String" resultMap="AuditElementInfoMap">
        SELECT
            _abc.*,
            cc."name" AS "shareUnitName",
            bb."ModelName" AS "secondModelName"
        FROM
            hpeapm.audit_elements_info _abc
            LEFT JOIN hpeapm."xbpj_company_model" bb
        ON _abc."second_model_number"= bb."ModelNo"
            LEFT JOIN (
            (SELECT DISTINCT
            CONCAT(busiUnitCode, orgCode) AS id,
            CONCAT(provinceName, '-', orgName) AS "name"
            FROM
            hpmgr."bonc_union_orginfos"
            WHERE "busiUnitCode" = 'CM000')
            UNION
            ALL
            (SELECT DISTINCT
            "busiUnitCode" AS id,
            "provinceName" AS "name"
            FROM
            hpmgr."bonc_union_orginfos"
            WHERE "busiUnitCode" != 'CM000'
            ORDER BY "busiUnitCode")
            ) cc
            ON _abc.share_unit = cc."id"
        WHERE audit_model_number = #{auditModelNumber};
    </select>
    <select id="selectWriteTime" parameterType="java.lang.String" resultType="java.lang.String">
        SELECT write_time
        FROM hpeapm.audit_elements_operation_steps
        WHERE audit_model_number = #{auditModelNumber}
          AND status = 2
          and delete_status = 1
    </select>

    <update id="updateModelEvaluationInfo">
