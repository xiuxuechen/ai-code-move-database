<mapper namespace="com.cxsj.mxzd.mapper.mysql.MysqlDataSupportCutInMapper">


    <resultMap type="com.cxsj.mxzd.pojo.DataCutInfo" id="AuditCutInMap">

        <result property="id" column="id"/>
        <result property="auditModelNumber" column="audit_model_number"/>
        <result property="dataContentDescriptionXq" column="data_content_description_xq"/>
        <result property="involvedSystem" column="involved_system"/>
        <result property="scopeOfDataXq" column="scope_of_data_xq"/>
    </resultMap>


