    <!--获取数据接入需求的数据 -->
    <select id="getSupportCutIn" parameterType="com.cxsj.mxzd.pojo.AuditElementsParam"
            resultMap="AuditCutInMap">
        SELECT *
        FROM
        audit_elements_data_cut_in
        WHERE 1=1
        <if test="auditModelNumber != null and auditModelNumber !=''">
            AND audit_model_number=like CONCAT('%', #{auditModelNumber}, '%')
        </if>
        AND isdel=1
    </select>


    <!--获取数据接入需求的数据 -->
