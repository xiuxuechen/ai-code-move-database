    <!--插入数据能力支撑数据资产管理和数据接入情况的中间表-->
    <insert id="insertSupportInCut" parameterType="com.cxsj.mxzd.pojo.SupportInCutInfo" >
        insert into audit_supp_in_cut
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="suppId != null and suppId !=''">supp_id,</if>
            <if test="auditModelNumber != null  and auditModelNumber != ''">audit_model_number,</if>
            <if test="cutId != null  and cutId != ''">cut_id,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="suppId != null and suppId !=''">like CONCAT('%', #{suppId}, '%'),</if>
            <if test="auditModelNumber != null  and auditModelNumber != ''">like CONCAT('%', #{auditModelNumber}, '%'),</if>
            <if test="cutId != null and cutId !=''">like CONCAT('%', #{cutId}, '%'),</if>
        </trim>
    </insert>


    <update id="updateSupportInCut" parameterType="com.cxsj.mxzd.pojo.DataCutInfo">
        UPDATE audit_supp_in_cut set cut_id=like CONCAT('%', #{cutId}, '%')
        <if test="auditModelNumber != null and auditModelNumber !=''">
            WHERE audit_model_number = like CONCAT('%', #{auditModelNumber}, '%')
        </if>
        <if test="suppId != null and suppId !=''">
            and supp_id = like CONCAT('%', #{suppId}, '%')
        </if>
    </update>


