                AND audit_model_number=like CONCAT('%', #{auditModelNumber}, '%')
            </if>
            AND isdel=1 AND remark is not null and  remark !=''  limit 1
        </select>-->


    <!--根据模型编号修改数据能力支撑数据资产管理-->
    <update id="updateAuditCutInDataBase" parameterType="com.cxsj.mxzd.pojo.AuditElementsParam">
        UPDATE audit_elements_data_cut_in
        <trim prefix="SET" suffixOverrides=",">
            <if test="dataContentDescriptionXq != null  and dataContentDescriptionXq != ''">
                data_content_description_xq=like CONCAT('%', #{dataContentDescriptionXq}, '%'),
            </if>
            <if test="involvedSystem != null  and involvedSystem != ''">involved_system=like CONCAT('%', #{involvedSystem}, '%'),</if>
            <if test="scopeOfDataXq != null  and scopeOfDataXq != ''">scope_of_data_xq=like CONCAT('%', #{scopeOfDataXq}, '%'),</if>
            <if test="isdel != null  and isdel != ''">isdel,</if>
        </trim>
        <if test="auditModelNumber != null and auditModelNumber !=''">
            WHERE audit_model_number = like CONCAT('%', #{auditModelNumber}, '%')
        </if>
        <if test="id != null and id !=''">
            AND id=like CONCAT('%', #{id}, '%')
        </if>
    </update>

    <!--插入数据能力支撑数据资产管理-->
    <insert id="insertAuditCutInDataBase" parameterType="com.cxsj.mxzd.pojo.DataCutInfo"
            useGeneratedKeys="true" keyProperty="id">
        insert into audit_elements_data_cut_in
        (data_content_description_xq,
        involved_system,
        audit_model_number,
        scope_of_data_xq,
        isdel)
        VALUE
        (like CONCAT('%', #{dataContentDescriptionXq}, '%'),
        like CONCAT('%', #{involvedSystem}, '%'),
        like CONCAT('%', #{auditModelNumber}, '%'),
        like CONCAT('%', #{scopeOfDataXq}, '%'),
        1);
    </insert>


    <!--新增，修改，或者删除审计支撑的时候先将审计支撑所有数据状态置位0-->
    <update id="updateAuditCutInDeleteStatus" parameterType="com.cxsj.mxzd.pojo.AuditElementsParam">
        UPDATE audit_elements_data_cut_in set isdel=0
        <if test="auditModelNumber != null and auditModelNumber !=''">
            WHERE audit_model_number = like CONCAT('%', #{auditModelNumber}, '%')
        </if>
    </update>


    <!--新增，修改，或者删除审计支撑的时候先将审计支撑所有数据状态置位0-->
    <delete id="deleteAuditSuppInCut" parameterType="com.cxsj.mxzd.pojo.AuditElementsParam">
        <if test="auditModelNumber != null and auditModelNumber !=''">
   delete from  audit_supp_in_cut     WHERE audit_model_number = like CONCAT('%', #{auditModelNumber}, '%')
        </if>
    </delete>


